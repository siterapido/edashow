# 🚀 EdaShow Environment Variables

# PayloadCMS
PAYLOAD_SECRET=gerar-um-secret-forte-aqui
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Database (Neon PostgreSQL)
# Local ou Produção
DATABASE_URI=postgresql://user:password@hostname:5432/dbname?sslmode=require

# Supabase Storage (S3 Compatible)
# Encontre estas informações em Supabase Project Settings > API e Storage
SUPABASE_BUCKET=media
SUPABASE_REGION=us-east-1
SUPABASE_ENDPOINT=https://xxxxxx.supabase.co/storage/v1/s3
SUPABASE_ACCESS_KEY_ID=sua-access-key
SUPABASE_SECRET_ACCESS_KEY=sua-secret-key

# Auth Roles (Opcional se quiser mudar padrões)
# PAYLOAD_ADMIN_EMAIL=admin@example.com
# PAYLOAD_ADMIN_PASSWORD=password

# WordPress Import API
# Generate a secure key: openssl rand -hex 32
WORDPRESS_IMPORT_API_KEY=your-secure-api-key-here
NEXT_PUBLIC_SITE_URL=https://edashow.com.br
